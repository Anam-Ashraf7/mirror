# Copy to `.env` (which is git-ignored) and fill in.
GEMINI_API_KEY=your-google-ai-studio-key-here

# Models — override the code defaults here. The latest Flash (Gemini 3.x) has far higher
# free-tier limits than Pro (~1500 vs ~50 requests/day) and now rivals Pro on quality.
# Confirm the exact model ids in Google AI Studio, then set them here. Avoid gemini-2.5-flash
# (end-of-life Oct 2026).
# MIRROR_LLM_MODEL is a COMMA-SEPARATED FALLBACK CHAIN: the prototype tries each in order
# and drops to the next when one returns 503 "high demand" (common for the newest model on
# free tier). Lite has the most headroom, so it's the backstop.
MIRROR_LLM_MODEL=gemini-3-flash-preview,gemini-3.1-flash-lite
MIRROR_VISION_MODEL=gemini-3-flash-preview
MIRROR_EMBED_MODEL=gemini-embedding-001
MIRROR_RERANK_MODEL=gemini-3.1-flash-lite

# FalkorDB connection (defaults match docker-compose.yml)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_DATABASE=mirror
