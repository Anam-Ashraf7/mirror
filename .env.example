# Copy to `.env` (which is git-ignored) and fill in.

# --- Provider switch -------------------------------------------------------------------
# Pick ONE active provider. Switching providers is a single line — the whole pipeline
# (extraction LLM + small model + embedder + reranker) moves with it.
#   gemini          -> Google Gemini (GEMINI_API_KEY)
#   openai          -> OpenAI          (OPENAI_API_KEY)
#   openai_generic  -> anyone OpenAI-compatible (DeepSeek/OpenRouter/Ollama/LiteLLM):
#                      set MIRROR_LLM_BASE_URL + MIRROR_LLM_MODEL + a key below
MIRROR_LLM_PROVIDER=openai

# --- Keys (only the active provider's key is required) ---------------------------------
GEMINI_API_KEY=your-google-ai-studio-key-here
OPENAI_API_KEY=your-openai-key-here          # OPEN_AI_API_KEY is also accepted

# --- Models -----------------------------------------------------------------------------
# Each provider ships sensible defaults in mirror/providers.py; override here to experiment.
# MIRROR_LLM_MODEL is a COMMA-SEPARATED FALLBACK CHAIN: the ingest loop tries each in order
# and drops to the next when one returns a transient 503/overload.
#
# OpenAI (primary-sourced pricing, per 1M in/out): gpt-5.4-nano $0.20/$1.25 (cheapest,
#   trying first) · gpt-5.4-mini $0.75/$4.50 · gpt-5.6-luna $1/$6 (newest small tier).
# MIRROR_LLM_MODEL=gpt-5.4-nano
# MIRROR_SMALL_MODEL=gpt-5.4-nano
# MIRROR_EMBED_MODEL=text-embedding-3-small
# MIRROR_RERANK_MODEL=gpt-5.4-nano
#
# Gemini: gemini-3-flash-preview $0.50/$3 (extraction) · gemini-3.1-flash-lite (cheap/lite).
# MIRROR_LLM_MODEL=gemini-3-flash-preview,gemini-3.1-flash-lite
# MIRROR_SMALL_MODEL=gemini-3.1-flash-lite
# MIRROR_EMBED_MODEL=gemini-embedding-001
# MIRROR_RERANK_MODEL=gemini-3.1-flash-lite
#
# openai_generic (e.g. DeepSeek): set the base_url + model + reuse OPENAI_API_KEY slot.
# MIRROR_LLM_BASE_URL=https://api.deepseek.com/v1
# MIRROR_LLM_MODEL=deepseek-chat

# Vision model for handwriting transcription (mirror/transcribe.py).
MIRROR_VISION_MODEL=gemini-3-flash-preview

# Concurrency for Graphiti's LLM calls. 1 is safe everywhere; raise it (e.g. 5) on a paid
# tier for faster ingests. Read at import, before graphiti_core loads.
# SEMAPHORE_LIMIT=1

# FalkorDB connection (defaults match docker-compose.yml)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_DATABASE=mirror
